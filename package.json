  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.10",
